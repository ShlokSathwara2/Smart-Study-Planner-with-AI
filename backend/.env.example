# Server Configuration
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?appName=SmartAI

# AI Provider - Primary (Groq)
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# AI Provider - Local (Ollama)
# Install Ollama from https://ollama.com and pull a model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# AI Provider - Optional fallback (Google Gemini)
# GEMINI_API_KEY=your_gemini_api_key_here

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333
